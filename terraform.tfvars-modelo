# Copie este arquivo para terraform.tfvars e ajuste os valores
# terraform.tfvars é ignorado pelo Git (.gitignore)

aws_region = "us-east-1"

# --- Habilite os módulos desejados ---
deploy_ec2     = false
deploy_rds     = false
deploy_lambda  = false
deploy_bedrock = false
deploy_eks     = false

# --- EC2 ---
ec2_instance_name = "example-dev"
ec2_instance_type = "t3.micro"

# --- RDS (obrigatório quando deploy_rds = true) ---
rds_db_name      = "appdb"
rds_db_username  = "appadmin"
rds_db_password  = "SUBSTITUIR_SENHA_SEGURA"
rds_allowed_cidr = "SEU_IP/32"

# --- Lambda ---
lambda_function_name = "my-python-lambda"

# --- Bedrock ---
bedrock_agent_name        = "example-bedrock-agent"
bedrock_agent_alias_name  = "dev"
bedrock_foundation_model  = "amazon.nova-lite-v1:0"
bedrock_agent_instruction = "You are a helpful assistant that answers user questions clearly and objectively."

# --- EKS ---
eks_cluster_name       = "eks-lab-min"
eks_node_capacity_type = "SPOT"
eks_desired_size       = 1
eks_min_size           = 0
eks_max_size           = 1
